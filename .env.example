# ============================================================================
# DeepFind CLI - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required fields are marked with TODO below.
# ============================================================================

# ============================================================================
# REQUIRED: Primary LLM API (choose one)
# ============================================================================

# TODO: Add your Qwen API key from https://dashscope.console.aliyun.com/
QWEN_API_KEY=your_qwen_api_key_here
QWEN_MODEL_NAME=qwen3-max
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ============================================================================
# OPTIONAL: Alternative LLM APIs
# ============================================================================
# Uncomment and configure if you want to use these models

# Xiaomi MiMo (use with --mimo flag)
# MIMO_API_KEY=your_mimo_api_key
# MIMO_MODEL_NAME=mimo-v2.5-pro
# MIMO_BASE_URL=https://api.xiaomimimo.com/v1

# MiniMax (use with --minimax flag)
# MINIMAX_API_KEY=your_minimax_api_key
# MINIMAX_MODEL_NAME=MiniMax-M2.7
# MINIMAX_BASE_URL=https://api.minimax.io/v1

# Local Ollama (use with --gpu flag)
# Defaults are already set in config, only override if needed
# DEEPFIND_LOCAL_BASE_URL=http://127.0.0.1:11434/v1
# DEEPFIND_LOCAL_MODEL=qwen3.5:9b
# DEEPFIND_LOCAL_API_KEY=ollama

# ============================================================================
# CLI TOOLS (auto-detected, override if custom paths needed)
# ============================================================================
OPENCLI_BIN=opencli
TWITTER_CLI_BIN=twitter
XHS_CLI_BIN=xhs
BILI_BIN=bili
YTDLP_BIN=yt-dlp
FFMPEG_BIN=ffmpeg

# ============================================================================
# ASR (Audio Speech Recognition) - Platform-Aware
# ============================================================================
# System auto-selects the best model for your platform:
# - macOS: mlx-whisper (Apple Silicon optimized)
# - PC (Linux/Windows): Qwen ASR (CUDA/CPU)
#
# Only change if you want different models:
ASR_MODEL_PC=Qwen/Qwen3-ASR-1.7B
ASR_MODEL_MAC=mlx-whisper:large-v3-mlx
#
# Other mlx-whisper options for Mac (smaller/faster):
# ASR_MODEL_MAC=mlx-whisper:medium
# ASR_MODEL_MAC=mlx-whisper:base
# ASR_MODEL_MAC=mlx-whisper:tiny

DEEPFIND_AUDIO_DIR=audio

# ============================================================================
# WEB UI SECURITY (optional but recommended for public access)
# ============================================================================
# TODO: Set a strong token if exposing web UI publicly
# Leave commented for local development
# DEEPFIND_WEB_TOKEN=your_secret_token_here

# CORS origins (comma-separated URLs allowed to access the API)
DEEPFIND_CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# ============================================================================
# IMAGE GENERATION (optional - for /gen-img command)
# ============================================================================
# TODO: Add Google API key if you want image generation
# Get from: https://aistudio.google.com/apikey
# GOOGLE_NANO_BANANA_API_KEY=your_google_api_key
# GOOGLE_NANO_BANANA_MODEL=gemini-3.1-flash-image-preview

DEEPFIND_IMAGE_DIR=tmp
DEEPFIND_IMAGE_SIZE=2K

# ============================================================================
# ADVANCED SETTINGS (usually don't need to change)
# ============================================================================
DEEPFIND_TOOL_TIMEOUT=90
